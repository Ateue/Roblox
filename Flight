local function makeTog(btn, dot, y, name)
    btn.Size = UDim2.new(0, 42, 0, 22)
    btn.Position = UDim2.new(0, 15, 0, y)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    btn.Text = ""
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
    dot.Size = UDim2.new(0, 18, 0, 18)
    dot.Position = UDim2.new(0, 2, 0.5, -9)
    dot.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
    Instance.new("UICorner", dot).CornerRadius = UDim.new(0, 3)
    local l = Instance.new("TextLabel", main)
    l.Size = UDim2.new(0, 100, 0, 22)
    l.Position = UDim2.new(0, 65, 0, y)
    l.BackgroundTransparency = 1
    l.Text = name
    l.TextColor3 = Color3.fromRGB(230, 230, 230)
    l.Font = "Gotham"
    l.TextSize = 14
    l.TextXAlignment = "Left"
end

makeTog(flyBtn, flyDot, 50, "Fly")
makeTog(clipBtn, clipDot, 80, "Noclip")

sBack.Size = UDim2.new(0, 135, 0, 4)
sBack.Position = UDim2.new(0, 15, 0, 130)
sBack.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
Instance.new("UICorner", sBack)
sFill.Size = UDim2.new(0, 0, 1, 0)
sFill.BackgroundColor3 = Color3.fromRGB(50, 100, 255)
Instance.new("UICorner", sFill)
sHandle.Size = UDim2.new(0, 8, 0, 16)
sHandle.Position = UDim2.new(1, -4, 0.5, -8)
sHandle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
Instance.new("UICorner", sHandle).CornerRadius = UDim.new(0, 2)

sInput.Size = UDim2.new(0, 50, 0, 26)
sInput.Position = UDim2.new(1, -60, 0, 118)
sInput.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
sInput.Text = "50"
sInput.TextColor3 = Color3.fromRGB(255, 255, 255)
sInput.Font = "GothamBold"
sInput.TextSize = 12
Instance.new("UICorner", sInput).CornerRadius = UDim.new(0, 4)
local st = Instance.new("UIStroke", sInput)
st.Color = Color3.fromRGB(60, 60, 60)
st.ApplyStrokeMode = "Border"
st.Thickness = 1.2

local drag, dStart, sPos
top.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = true dStart = i.Position sPos = main.Position end end)
uis.InputChanged:Connect(function(i) if drag and i.UserInputType == Enum.UserInputType.MouseMovement then local delta = i.Position - dStart main.Position = UDim2.new(sPos.X.Scale, sPos.X.Offset + delta.X, sPos.Y.Scale, sPos.Y.Offset + delta.Y) end end)
uis.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end end)

local flying, noclip, speed = false, false, 50
local ctrl = {f = 0, b = 0, l = 0, r = 0}
local sliding = false
local bv, bg

local function update(v)
    speed = math.clamp(v, 30, 300)
    sInput.Text = tostring(speed)
    sFill.Size = UDim2.new((speed - 30) / 270, 0, 1, 0)
end
update(50)

sBack.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = true end end)
uis.InputChanged:Connect(function(i) if sliding and i.UserInputType == Enum.UserInputType.MouseMovement then local x = math.clamp((i.Position.X - sBack.AbsolutePosition.X) / sBack.AbsoluteSize.X, 0, 1) update(math.floor(30 + (x * 270))) end end)
uis.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end end)
sInput.FocusLost:Connect(function() local n = tonumber(sInput.Text) update(n or speed) end)

local function cleanFly()
    if bv then bv:Destroy() bv = nil end
    if bg then bg:Destroy() bg = nil end
    if lp.Character and lp.Character:FindFirstChild("Humanoid") then lp.Character.Humanoid.PlatformStand = false end
end

flyBtn.MouseButton1Click:Connect(function()
    flying = not flying
    flyBtn.BackgroundColor3 = flying and Color3.fromRGB(50, 100, 255) or Color3.fromRGB(30, 30, 30)
    flyDot:TweenPosition(flying and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9), "Out", "Quad", 0.1)
    if not flying then cleanFly() end
end)

clipBtn.MouseButton1Click:Connect(function()
    noclip = not noclip
    clipBtn.BackgroundColor3 = noclip and Color3.fromRGB(50, 100, 255) or Color3.fromRGB(30, 30, 30)
    clipDot:TweenPosition(noclip and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9), "Out", "Quad", 0.1)
end)

rs.RenderStepped:Connect(function()
    if flying and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") and lp.Character:FindFirstChild("Humanoid") then
        local root = lp.Character.HumanoidRootPart
        local hum = lp.Character.Humanoid
        hum.PlatformStand = true
        if not bv then
            bv = Instance.new("BodyVelocity", root)
            bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        end
        if not bg then
            bg = Instance.new("BodyGyro", root)
            bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
        end
        local cam = workspace.CurrentCamera.CFrame
        bv.Velocity = ((cam.LookVector * (ctrl.f + ctrl.b)) + (cam * CFrame.new(ctrl.l + ctrl.r, (ctrl.f + ctrl.b) * 0.2, 0).Position - cam.Position)) * speed
        bg.CFrame = cam
    elseif not flying and bv then
        cleanFly()
    end
end)

rs.Stepped:Connect(function()
    if noclip and lp.Character then
        for _, v in pairs(lp.Character:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end
end)

uis.InputBegan:Connect(function(i, g)
    if g then return end
    if i.KeyCode == Enum.KeyCode.W then ctrl.f = 1
    elseif i.KeyCode == Enum.KeyCode.S then ctrl.b = -1
    elseif i.KeyCode == Enum.KeyCode.A then ctrl.l = -1
    elseif i.KeyCode == Enum.KeyCode.D then ctrl.r = 1 end
end)

uis.InputEnded:Connect(function(i)
    if i.KeyCode == Enum.KeyCode.W then ctrl.f = 0
    elseif i.KeyCode == Enum.KeyCode.S then ctrl.b = 0
    elseif i.KeyCode == Enum.KeyCode.A then ctrl.l = 0
    elseif i.KeyCode == Enum.KeyCode.D then ctrl.r = 0 end
end)

lp.CharacterAdded:Connect(function()
    task.wait(0.1)
    if flying then cleanFly() end
end)
