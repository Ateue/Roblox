local top = Instance.new("Frame", main)
local title = Instance.new("TextLabel", top)
local close = Instance.new("TextButton", main)
local flyBtn = Instance.new("TextButton", main)
local flyDot = Instance.new("Frame", flyBtn)
local clipBtn = Instance.new("TextButton", main)
local clipDot = Instance.new("Frame", clipBtn)
local sBack = Instance.new("Frame", main)
local sFill = Instance.new("Frame", sBack)
local sHandle = Instance.new("Frame", sFill)
local sInput = Instance.new("TextBox", main)

main.Size = UDim2.new(0, 220, 0, 160)
main.Position = UDim2.new(0.7, 0, 0.25, 0)
main.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
corner.CornerRadius = UDim.new(0, 6)

top.Size = UDim2.new(1, 0, 0, 40)
