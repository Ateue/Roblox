local drag, dStart, sPos
top.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = true dStart = i.Position sPos = main.Position end end)
uis.InputChanged:Connect(function(i) if drag and i.UserInputType == Enum.UserInputType.MouseMovement then local delta = i.Position - dStart main.Position = UDim2.new(sPos.X.Scale, sPos.X.Offset + delta.X, sPos.Y.Scale, sPos.Y.Offset + delta.Y) end end)
uis.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end end)

local function FarmCycle()
    local char = lp.Character or lp.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart", 5)
    if not hrp then return end
    
    local teamName = lp.Team and lp.Team.Name or "White"
    local modelName = TeamModels[teamName] or "WhiteZone"
    
    pcall(function()
        workspace[modelName].VoteLaunchRE:FireServer()
    end)
    
    local floor = Instance.new("Part")
    floor.Size = Vector3.new(15, 1, 15)
    floor.Anchored = true
    floor.Transparency = 1
    floor.Parent = workspace
    
    local conn = rs.Heartbeat:Connect(function()
        if hrp and hrp.Parent and floor.Parent then 
            floor.CFrame = hrp.CFrame * CFrame.new(0, -3.2, 0) 
        end
    end)
    
    local stages = workspace:WaitForChild("BoatStages"):WaitForChild("NormalStages")
    for i = 1, 10 do
        if not isFarming or not hrp.Parent then break end
        local stage = stages:FindFirstChild("CaveStage"..i)
        if stage and stage:FindFirstChild("DarknessPart") then
            hrp.CFrame = stage.DarknessPart.CFrame
            task.wait(2)
        end
    end
    
    if isFarming and hrp.Parent then
        hrp.CFrame = CFrame.new(-113, 177, 8819)
        task.wait(0.5)
        hrp.CFrame = CFrame.new(-55, -360, 9488)
        task.wait(2)
    end
    
    conn:Disconnect()
    floor:Destroy()
    
    if hrp.Parent then char:BreakJoints() end
end

farmBtn.MouseButton1Click:Connect(function()
    isFarming = not isFarming
    farmBtn.BackgroundColor3 = isFarming and Color3.fromRGB(50, 100, 255) or Color3.fromRGB(30, 30, 30)
    farmDot:TweenPosition(isFarming and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9), "Out", "Quad", 0.1)
    
    if isFarming then
        task.spawn(function()
            while isFarming do
                pcall(FarmCycle)
                if isFarming then
                    task.wait(0.1)
                end
            end
        end)
    end
end)

