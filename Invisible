local lp = game:GetService("Players").LocalPlayer
local rs = game:GetService("RunService")
local uis = game:GetService("UserInputService")

if _G.InvData then
    _G.InvData.Active = false
    task.wait()
    for _, v in pairs(_G.InvData.Conns) do v:Disconnect() end
    if _G.InvData.Gui then _G.InvData.Gui:Destroy() end
    _G.InvData = nil
end

local gui = Instance.new("ScreenGui")
gui.Name = "INV_V13"
gui.ResetOnSpawn = false
gui.DisplayOrder = 999
gui.Parent = (gethui and gethui()) or lp:WaitForChild("PlayerGui")

local main = Instance.new("Frame", gui)
local corner = Instance.new("UICorner", main)
local top = Instance.new("Frame", main)
local title = Instance.new("TextLabel", top)
local close = Instance.new("TextButton", main)
local btn = Instance.new("TextButton", main)
local dot = Instance.new("Frame", btn)
local hint = Instance.new("TextLabel", main)

main.Size = UDim2.new(0, 180, 0, 90)
main.Position = UDim2.new(0.5, -90, 0.1, 0)
main.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
main.BorderSizePixel = 0
corner.CornerRadius = UDim.new(0, 4)

top.Size = UDim2.new(1, 0, 0, 30)
top.BackgroundTransparency = 1
title.Size = UDim2.new(1, 0, 1, 0)
title.Position = UDim2.new(0, 12, 0, 0)
title.Text = "Invisible"
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.Font = Enum.Font.GothamBold
title.TextSize = 13
title.TextXAlignment = Enum.TextXAlignment.Left
title.BackgroundTransparency = 1

close.Size = UDim2.new(0, 18, 0, 18)
close.Position = UDim2.new(1, -24, 0, 6)
close.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
