local cL, cR = {}, {}
local function getCPS(t)
	local n = os.clock()
	for i = #t, 1, -1 do
		if n - t[i] > 1 then table.remove(t, i) end
	end
	return #t
end

uis.InputBegan:Connect(function(i, g)
	if g then return end
	local k = MainKeys:FindFirstChild(i.KeyCode.Name) or MainKeys:FindFirstChild(i.UserInputType.Name)
	if k then
		ts:Create(k, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(255, 255, 255), TextColor3 = Color3.fromRGB(0, 0, 0)}):Play()
		if i.UserInputType == Enum.UserInputType.MouseButton1 then table.insert(cL, os.clock())
		elseif i.UserInputType == Enum.UserInputType.MouseButton2 then table.insert(cR, os.clock()) end
	end
end)

uis.InputEnded:Connect(function(i)
	local k = MainKeys:FindFirstChild(i.KeyCode.Name) or MainKeys:FindFirstChild(i.UserInputType.Name)
	if k then
		ts:Create(k, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(10, 10, 10), TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
	end
end)

local frames, last = 0, os.clock()
local curFps = 0

rs.RenderStepped:Connect(function()
	frames = frames + 1
	if os.clock() - last >= 1 then
		curFps = frames
		frames = 0
		last = os.clock()
	end
	CPS.Text = getCPS(cL) .. " | " .. getCPS(cR) .. " CPS"
	FPS.Text = curFps .. " FPS"
end)
