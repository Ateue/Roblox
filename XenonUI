function LibraryV2.UI(Name)
    if CoreGui:FindFirstChild("XenonUI") then
        CoreGui:FindFirstChild("XenonUI"):Destroy()
    end

    local ScreenGui, MainFrame, TopBar, TitleLabel, CloseButton, TabBar, ContentArea, DragButton, NotificationHolder = CreateUI()

    local Library = {
        _ScreenGui = ScreenGui,
        _MainFrame = MainFrame,
        _TopBar = TopBar,
        _TitleLabel = TitleLabel,
        _CloseButton = CloseButton,
        _TabBar = TabBar,
        _ContentArea = ContentArea,
        _DragButton = DragButton,
        _NotificationHolder = NotificationHolder,
        Name = Name or "Xenon",
        Tabs = {},
        State = false,
        ToggleKey = Enum.KeyCode.RightControl,
        Debounce = false,
        ActiveTab = nil,

        Show_UI = function(self_lib)
            self_lib = self_lib or Library
            self_lib.State = true
            self_lib._MainFrame.Visible = true
            self_lib._MainFrame.Size = u2(0, 0, 0, 0)
            self_lib._MainFrame.Position = u2(0.5, 0, 0.5, 0)
            local sx = IsMobile and 380 or 550
            local sy = IsMobile and 350 or 400
            Tween(self_lib._MainFrame, {
                Size = u2(0, sx, 0, sy),
                Position = u2(0.5, -sx/2, 0.5, -sy/2)
            }, 0.3)
        end,

        Hide_UI = function(self_lib)
            self_lib = self_lib or Library
            self_lib.State = false
            Tween(self_lib._MainFrame, {
                Size = u2(0, 0, 0, 0),
                Position = u2(0.5, 0, 0.5, 0)
            }, 0.25, true)
            self_lib._MainFrame.Visible = false
        end,

        Toggle_UI = function(self_lib)
            self_lib = self_lib or Library
            if self_lib.Debounce then return end
            self_lib.Debounce = true
            if self_lib.State then
                Library.Hide_UI()
            else
                Library.Show_UI()
            end
            task.wait(0.35)
            self_lib.Debounce = false
        end,

        SwitchTab = function(tab)
            for _, child in pairs(Library._ContentArea:GetChildren()) do
                if child:IsA("Frame") then
                    child.Visible = false
                end
            end
            for _, t in pairs(Library.Tabs) do
                if t._TabButton then
                    t._TabButton.BackgroundColor3 = Color3.fromRGB(35, 35, 52)
                end
            end
            if tab._ContentFrame then
                tab._ContentFrame.Visible = true
            end
            if tab._TabButton then
                tab._TabButton.BackgroundColor3 = Color3.fromRGB(55, 55, 85)
            end
            Library.ActiveTab = tab
        end
    }

    TitleLabel.Text = Library.Name
    ScreenGui.Parent = CoreGui

    pcall(function()
        StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.PlayerList, true)
    end)

    CloseButton.MouseButton1Click:Connect(function()
        Library.Hide_UI()
    end)

    if IsMobile then
        CloseButton.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch then
                Library.Hide_UI()
            end
        end)
    end

    DragButton.MouseButton1Click:Connect(function()
        Library.Toggle_UI()
    end)

    if IsMobile then
        DragButton.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch then
                local totalMove = 0
                if input.Position and DragButton.Position then
                    totalMove = (input.Position - (dragStart or input.Position)).Magnitude
                end
            end
        end)

        local touchStart
        local moved = false
        DragButton.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch then
                touchStart = input.Position
                moved = false
            end
        end)

        DragButton.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch then
                if touchStart and (input.Position - touchStart).Magnitude > 10 then
                    moved = true
                end
            end
        end)

        DragButton.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch and not moved then
                Library.Toggle_UI()
            end
        end)
    end

    if not IsMobile then
        UserInputService.InputBegan:Connect(function(Key, IsTyping)
            if IsTyping then return end
            if Key.KeyCode == Library.ToggleKey then
                Library.Toggle_UI()
            end
        end)
    end

    return setmetatable(Library, LibraryV2)
end

