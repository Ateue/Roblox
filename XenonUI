    KBFrame.TextSize = IsMobile and 12 or 14
    KBFrame.Font = Enum.Font.GothamSemibold
    KBFrame.TextXAlignment = Enum.TextXAlignment.Left
    KBFrame.BorderSizePixel = 0
    KBFrame.ZIndex = 62
    KBFrame.AutoButtonColor = false
    KBFrame.Parent = self._ContentHolder

    local kCorner = Instance.new("UICorner")
    kCorner.CornerRadius = UDim.new(0, 6)
    kCorner.Parent = KBFrame

    local KeyLabel = Instance.new("TextLabel")
    KeyLabel.Name = "KeyLabel"
    KeyLabel.Size = u2(0, 60, 0, IsMobile and 22 or 24)
    KeyLabel.Position = u2(1, -70, 0.5, -(IsMobile and 11 or 12))
    KeyLabel.BackgroundColor3 = Color3.fromRGB(25, 25, 40)
    KeyLabel.TextColor3 = Color3.fromRGB(150, 150, 200)
    KeyLabel.TextSize = IsMobile and 10 or 12
    KeyLabel.Font = Enum.Font.GothamBold
    KeyLabel.BorderSizePixel = 0
    KeyLabel.ZIndex = 64
    KeyLabel.Parent = KBFrame

    local klCorner = Instance.new("UICorner")
    klCorner.CornerRadius = UDim.new(0, 5)
    klCorner.Parent = KeyLabel

    table.insert(self.Assets, KBFrame)

    local Blacklist = BlacklistedKeys or {"W", "A", "S", "D"}

    local function GetKeyString(key)
        local str = tostring(key)
        if str:find("Enum.KeyCode.") then
            return str:sub(15)
        end
        return str
    end

    local Keybind = {
        Name = Name,
        Key = StartingKey or Enum.KeyCode.E,
        Callback = Callback or function() end,
        Class = "Keybind",
        Asset = KBFrame,
        _Listening = false,

        Update = function(kb)
            KeyLabel.Text = GetKeyString(kb.Key)
        end
    }

    Keybind.Update(Keybind)

    UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if Keybind._Listening then return end
        if input.KeyCode == Keybind.Key then
            pcall(Keybind.Callback)
        end
    end)

    KBFrame.MouseButton1Click:Connect(function()
        if Keybind._Listening then return end
        Keybind._Listening = true
        KeyLabel.Text = "..."

        local conn
        conn = UserInputService.InputBegan:Connect(function(input, gpe)
            if gpe then return end
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 then return end

            if input.KeyCode == Enum.KeyCode.Escape or input.KeyCode == Enum.KeyCode.Return then
                Keybind._Listening = false
                Keybind.Update(Keybind)
                conn:Disconnect()
                return
            end

            local keyStr = GetKeyString(input.KeyCode)
            if not table.find(Blacklist, keyStr) then
                Keybind.Key = input.KeyCode
                Keybind.Update(Keybind)
            end

            Keybind._Listening = false
            conn:Disconnect()
        end)
    end)

    if self.State ~= nil and self.UpdateSize then
        task.delay(0.05, function()
            if self.State then
                self.UpdateSize(self)
            end
        end)
    end

    return setmetatable(Keybind, LibraryV2)
end

function LibraryV2:Update_(a_1)
    local Class = self.Class
    if not a_1 then return end

    if Class == "Button" then
        self.Callback = a_1
    elseif Class == "Toggle" then
        self.State = a_1
        self.Update(self)
        task.spawn(function()
            pcall(self.Callback, self.State)
        end)
    elseif Class == "Label" then
        self.Text = a_1
        self.Update(self)
    elseif Class == "Slider" then
        self.Value = a_1
        self.Update(self)
    elseif Class == "Dropdown" then
        self.List = a_1
        self.Update(self)
    end
end

