function Tween(inst, tType, t, yield)
    if not inst then return end
    local tw = TweenService:Create(inst, TweenInfo.new(t or 0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), tType)
    tw:Play()
    if yield then
        tw.Completed:Wait()
    end
    return tw
end

function RoundNumber(num, numDecimalPlaces)
    return tonumber(string.format("%." .. (numDecimalPlaces or 0) .. "f", num))
end

function Ripple(asset, x, y)
    if not asset or not x or not y then return end
    coroutine.wrap(function()
        local circle = Instance.new("Frame")
        circle.Name = "Ripple"
        circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        circle.BackgroundTransparency = 0.7
        circle.BorderSizePixel = 0
        circle.ZIndex = 100
        circle.AnchorPoint = Vector2.new(0.5, 0.5)
        circle.Position = u2(0, x - asset.AbsolutePosition.X, 0, y - asset.AbsolutePosition.Y)
        circle.Size = u2(0, 0, 0, 0)
        circle.Parent = asset

        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(1, 0)
        corner.Parent = circle

        circle.ClipsDescendants = true
        asset.ClipsDescendants = true

        local size = math.max(asset.AbsoluteSize.X, asset.AbsoluteSize.Y) * 2
        local tw = TweenService:Create(circle, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = u2(0, size, 0, size),
            BackgroundTransparency = 1
        })
        tw:Play()
        tw.Completed:Wait()
        circle:Destroy()
    end)()
end

