local function makeTog(y, name, key)
    local btn = Instance.new("TextButton", main)
    local dot = Instance.new("Frame", btn)
    local lab = Instance.new("TextLabel", main)
    
    btn.Size = UDim2.new(0, 36, 0, 18)
    btn.Position = UDim2.new(0, 15, 0, y)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    btn.Text = ""
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
    
    dot.Size = UDim2.new(0, 14, 0, 14)
    dot.Position = UDim2.new(0, 2, 0.5, -7)
    dot.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
    Instance.new("UICorner", dot).CornerRadius = UDim.new(0, 3)
    
    lab.Size = UDim2.new(0, 120, 0, 18)
    lab.Position = UDim2.new(0, 60, 0, y)
    lab.BackgroundTransparency = 1
    lab.Text = name
    lab.TextColor3 = Color3.fromRGB(200, 200, 200)
    lab.Font = "Gotham"
    lab.TextSize = 13
    lab.TextXAlignment = "Left"
    
    btn.MouseButton1Click:Connect(function()
        state[key] = not state[key]
        btn.BackgroundColor3 = state[key] and Color3.fromRGB(50, 100, 255) or Color3.fromRGB(30, 30, 30)
        dot:TweenPosition(state[key] and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7), "Out", "Quad", 0.1)
    end)
end

